    \x1b[31m69:     78:         line_colored = colored(lines[line_num], "red") if use_color else lines[line_num]\x1b[0m
    \x1b[31m71:     111:         (args.color == "auto" and sys.stdout.isatty() and colored)\x1b[0m
    \x1b[31m72:     113:     if use_color and not colored:\x1b[0m
    \x1b[2m81  try:\x1b[0m
    \x1b[31m82:     from termcolor import colored\x1b[0m
    \x1b[2m83  except ImportError as exc:\x1b[0m
    \x1b[31m84:     colored = None\x1b[0m
    \x1b[2m110  def print_inline(paths, lines, use_color):\x1b[0m
    \x1b[2m112      for line_num, path in paths:\x1b[0m
    \x1b[2m115          if use_color:\x1b[0m
    \x1b[31m116:             path_str = colored(path_str, attrs=["dark"])\x1b[0m
    \x1b[31m117:             line = colored(line, "red")\x1b[0m
    \x1b[2m120  def print_full_lines(paths, lines, use_color):\x1b[0m
    \x1b[2m124      for line_num, path in paths:\x1b[0m
    \x1b[2m126          for key, indent, i in path[:-1]:\x1b[0m
    \x1b[31m127:             line_colored = colored(lines[i], attrs=["dark"]) if use_color else lines[i]\x1b[0m
    \x1b[31m131:         line_colored = colored(lines[line_num], "red") if use_color else lines[line_num]\x1b[0m
    \x1b[2m162      use_color = (\x1b[0m
    \x1b[31m164:         (args.color == "auto" and sys.stdout.isatty() and colored)\x1b[0m
    \x1b[31m166:     if use_color and not colored:\x1b[0m


"""  # noqa: E501

import argparse
import os
import re
import subprocess
import sys

try:
    from termcolor import colored
except ImportError:
    colored = None


class ColoredHelpFormatter(argparse.RawDescriptionHelpFormatter):
    """Formatter that strips ANSI color codes from help text if terminal doesn't support colors."""

    def _strip_ansi(self, text):
        """Strip ANSI escape codes from text."""
        # Match ANSI escape sequences
        ansi_escape = re.compile(r"\x1b\[[0-9;]*m")
        return ansi_escape.sub("", text)

    def format_help(self):
        """Format help, stripping colors if stdout is not a TTY."""
        help_text = super().format_help()
        # Strip colors if not outputting to a TTY
        if not sys.stdout.isatty():
            help_text = self._strip_ansi(help_text)
        return help_text


def get_github_context():
    """Return (repo_toplevel, commit_sha, github_blob_base) or None.

    Resolves git repository info and GitHub remote URL to construct
    blob URLs like https://github.com/owner/repo/blob/sha.
    """
    try:
        toplevel = (
            subprocess.check_output(
                ["git", "rev-parse", "--show-toplevel"], stderr=subprocess.DEVNULL
            )
            .decode()
            .strip()
        )
        sha = (
            subprocess.check_output(
                ["git", "rev-parse", "HEAD"], stderr=subprocess.DEVNULL
            )
            .decode()
            .strip()
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None

    # Determine remote name: tracking remote for current branch, fallback to origin
    remote_name = "origin"
    try:
        ref = (
            subprocess.check_output(
                ["git", "symbolic-ref", "-q", "HEAD"], stderr=subprocess.DEVNULL
            )
            .decode()
            .strip()
        )
        branch = ref.replace("refs/heads/", "")
        remote_name = (
            subprocess.check_output(
                ["git", "config", f"branch.{branch}.remote"], stderr=subprocess.DEVNULL
            )
            .decode()
            .strip()
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass

    try:
        remote_url = (
            subprocess.check_output(
                ["git", "config", "--get", f"remote.{remote_name}.url"],
                stderr=subprocess.DEVNULL,
            )
            .decode()
            .strip()
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None

    # Parse SSH or HTTPS GitHub URLs
    # SSH: git@github.com:owner/repo.git
    m = re.match(r"git@github\.com[:/](.+?)(?:\.git)?$", remote_url)
    if not m:
        # HTTPS: https://github.com/owner/repo.git
        m = re.match(r"https?://github\.com/(.+?)(?:\.git)?$", remote_url)
    if not m:
        # gh: shorthand
        m = re.match(r"gh:(.+?)(?:\.git)?$", remote_url)
    if not m:
        return None

    owner_repo = m.group(1)
    blob_base = f"https://github.com/{owner_repo}/blob/{sha}"
    return toplevel, sha, blob_base


def get_paths(lines):
    """Generate indentation-based paths for given lines."""
    paths = []
    path_stack = []

    for i, line in enumerate(lines):
        stripped = line.lstrip()
        indent = len(line) - len(stripped)

        # Adjust the stack based on indentation
        while path_stack and path_stack[-1][1] >= indent:
            path_stack.pop()

        # Extract the "key" (first non-space word before :, {, etc.)
        if stripped:
            key = stripped.split()[0].rstrip(":{")
            if key:
                path_stack.append((key, indent, i))

        # Build the path
        paths.append((i, tuple(path_stack)))

    return paths


def print_inline(paths, lines, use_color, prefix=""):
    """Print paths and matched lines in inline format."""
    for line_num, path in paths:
        path_str = ".".join([p[0] for p in path[:-1]])
        line = lines[line_num].rstrip()
        if use_color:
            path_str = colored(path_str, attrs=["dark"])
            line = colored(line, "red")
        print(f"{prefix}{line_num}: {path_str} {line}")


def print_full_lines(paths, lines, use_color, prefix=""):
    """Print paths and matched lines in full-lines format."""
    printed = set()
    for line_num, path in paths:
        # in simplest case -- print all lines of the path
        for key, indent, i in path[:-1]:
            line_colored = colored(lines[i], attrs=["dark"]) if use_color else lines[i]
            if i not in printed:
                print(f"{prefix}{i}  {line_colored}")
                printed.add(i)
        line_colored = colored(lines[line_num], "red") if use_color else lines[line_num]
        print(f"{prefix}{line_num}: {line_colored}")
        printed.add(line_num)


def print_inline_markdown(paths, lines, blob_url, use_color, prefix=""):
    """Print paths and matched lines in inline format with GitHub markdown links."""
    for line_num, path in paths:
        path_str = ".".join([p[0] for p in path[:-1]])
        line = lines[line_num].rstrip()
        # GitHub uses 1-indexed line numbers
        gh_line = line_num + 1
        path_part = f" `{path_str}`" if path_str else ""
        if blob_url:
            text = f"**[`{line_num}:`]({blob_url}#L{gh_line}){path_part} `{line}`**"
        else:
            text = f"**`{line_num}:`{path_part} `{line}`**"
        if use_color:
            text = colored(text, "red")
        print(f"{prefix}{text}")


def print_full_lines_markdown(paths, lines, blob_url, use_color, prefix=""):
    """Print paths and matched lines in full-lines format with GitHub markdown links."""
    printed = set()
    for line_num, path in paths:
        for key, indent, i in path[:-1]:
            if i not in printed:
                gh_i = i + 1
                context_line = lines[i]
                if blob_url:
                    text = f"[`{i} `]({blob_url}#L{gh_i}) `{context_line}`"
                else:
                    text = f"`{i} ` `{context_line}`"
                if use_color:
                    text = colored(text, attrs=["dark"])
                print(f"{prefix}{text}")
                printed.add(i)
        gh_line = line_num + 1
        match_line = lines[line_num]
        if blob_url:
            text = f"**[`{line_num}:`]({blob_url}#L{gh_line}) `{match_line}`**"
        else:
            text = f"**`{line_num}:` `{match_line}`**"
        if use_color:
            text = colored(text, "red")
        print(f"{prefix}{text}")
        printed.add(line_num)


def filter_paths(lines, regex=None, line_numbers=None):
    """Get and filter indentation-based paths for given lines."""
    paths = get_paths(lines)

    if regex:
        paths = [
            (line_num, path)
            for line_num, path in paths
            if regex.search(lines[line_num])
        ]

    if line_numbers:
        nums = set(line_numbers)
        paths = [(line_num, path) for line_num, path in paths if line_num in nums]

    return paths


def main():
    parser = argparse.ArgumentParser(
        description=__doc__, formatter_class=ColoredHelpFormatter
    )
    parser.add_argument(
        "file",
        nargs="*",
        help="Input file(s) to process (default: stdin)",
    )
    parser.add_argument(
        "-e", "--regex", type=str, help="Regular expression to match lines"
    )
    parser.add_argument(
        "-n",
        "--line-number",
        type=int,
        action="append",
        help="Specific line number(s) to print (can be used multiple times)",
    )
    parser.add_argument(
        "-f",
        "--format",
        choices=["inline", "full-lines"],
        default="inline",
        help="Output format: 'inline' (default) or 'full-lines'",
    )
    parser.add_argument(
        "--color",
        choices=["auto", "on", "off"],
        default="auto",
        help="Color output: 'auto' (default), 'on', or 'off'",
    )
    parser.add_argument(
        "--filename",
        choices=["auto", "prefix", "name"],
        default="auto",
        help="How to annotate output with filename: 'auto' (prefix when multiple files),"
        " 'prefix' (prepend filename: to each line), 'name' (print filename header)",
    )
    parser.add_argument(
        "-D",
        "--decorations",
        choices=["auto", "color", "none", "github-markdown"],
        default="auto",
        help="Decoration style: 'auto' (defers to --color), 'color' (force ANSI),"
        " 'none' (plain text), 'github-markdown' (markdown with GitHub blob links)",
    )

    args = parser.parse_args()

    decorations = args.decorations

    # Determine if color output should be used
    if decorations == "auto":
        # Defer to --color logic (backward compatible)
        use_color = args.color == "on" or (
            args.color == "auto" and sys.stdout.isatty() and colored
        )
    elif decorations == "color":
        use_color = True
    elif decorations == "none":
        use_color = False
    elif decorations == "github-markdown":
        # Colors on top of markdown when TTY
        use_color = sys.stdout.isatty() and colored is not None
    else:
        use_color = False

    if use_color and not colored:
        raise RuntimeError("Need 'termcolor' package to get colors")

    # Resolve GitHub context if needed
    github_context = None
    if decorations == "github-markdown":
        github_context = get_github_context()
        if github_context is None:
            print(
                "Error: --decorations=github-markdown requires a git repo"
                " with a GitHub remote",
                file=sys.stderr,
            )
            sys.exit(1)

    # Compile regex if provided
    regex = re.compile(args.regex) if args.regex else None

    # Determine file list: use provided files or stdin
    files = args.file if args.file else [None]  # None means stdin

    # Resolve filename display mode
    filename_mode = args.filename
    if filename_mode == "auto":
        filename_mode = "prefix" if len(files) > 1 else None

    for filepath in files:
        if filepath is None:
            lines = sys.stdin.readlines()
            fname = "<stdin>"
        else:
            with open(filepath) as f:
                lines = f.readlines()
            fname = filepath

        lines = [line.rstrip() for line in lines]

        paths = filter_paths(lines, regex=regex, line_numbers=args.line_number)
        if not paths:
            continue

        if decorations == "github-markdown":
            # Compute blob URL for this file
            if filepath is not None and github_context is not None:
                toplevel, _sha, blob_base = github_context
                rel_path = os.path.relpath(os.path.abspath(filepath), toplevel)
                blob_url = f"{blob_base}/{rel_path}"
            else:
                blob_url = None

            # Build markdown prefix/header with hyperlinked filename
            if filename_mode == "prefix":
                if blob_url:
                    prefix = f"[`{fname}`]({blob_url}):"
                else:
                    prefix = f"`{fname}`:"
            else:
                prefix = ""

            if filename_mode == "name":
                if blob_url:
                    print(f"[`{fname}`]({blob_url})")
                else:
                    print(f"`{fname}`")

            if args.format == "inline":
                print_inline_markdown(paths, lines, blob_url, use_color, prefix=prefix)
            elif args.format == "full-lines":
                print_full_lines_markdown(
                    paths, lines, blob_url, use_color, prefix=prefix
                )
            else:
                raise ValueError(args.format)
        else:
            prefix = f"{fname}:" if filename_mode == "prefix" else ""

            if filename_mode == "name":
                print(fname)
            if args.format == "inline":
                print_inline(paths, lines, use_color, prefix=prefix)
            elif args.format == "full-lines":
                print_full_lines(paths, lines, use_color, prefix=prefix)
            else:
                raise ValueError(args.format)


if __name__ == "__main__":
    main()
